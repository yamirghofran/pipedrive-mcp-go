# ===========================================
# Pipedrive MCP Server - Required
# ===========================================
PIPEDRIVE_API_TOKEN=your_api_token_here
PIPEDRIVE_DOMAIN=your-company.pipedrive.com

# ===========================================
# Transport Configuration (Optional)
# ===========================================
# Transport mode: "stdio" (default) or "http"
MCP_TRANSPORT=stdio
# HTTP listen port (http transport only)
MCP_PORT=3000
# HTTP listen host (use 0.0.0.0 for Docker)
MCP_HOST=localhost

# ===========================================
# JWT Authentication (Optional, HTTP transport only)
# ===========================================
# HMAC secret or PEM-encoded public key for JWT verification
# MCP_JWT_SECRET=your-secret-key
# JWT signing algorithm (HS256, HS384, HS512, RS256, RS384, RS512)
# MCP_JWT_ALGORITHM=HS256
# Expected JWT audience claim
# MCP_JWT_AUDIENCE=mcp-server
# Expected JWT issuer claim
# MCP_JWT_ISSUER=my-app

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# Minimum time between Pipedrive API calls
# PIPEDRIVE_RATE_LIMIT_MIN_INTERVAL=250ms
# Maximum concurrent Pipedrive API calls
# PIPEDRIVE_RATE_LIMIT_MAX_CONCURRENT=2

# ===========================================
# Session Management (Optional, HTTP transport)
# ===========================================
# Maximum SSE session lifetime
# MCP_SESSION_MAX_AGE=1h
# Session cleanup interval
# MCP_SESSION_CLEANUP_INTERVAL=5m
# Maximum concurrent sessions
# MCP_SESSION_MAX_COUNT=100

# ===========================================
# Custom Fields (Optional)
# ===========================================
# Pipedrive custom field key for booking details
# PIPEDRIVE_BOOKING_FIELD_KEY=8f4b27fbd9dfc70d2296f23ce76987051ad7324e

# ===========================================
# TLS (Optional, HTTP transport)
# ===========================================
# MCP_TLS_CERT=/path/to/cert.pem
# MCP_TLS_KEY=/path/to/key.pem
